{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/raphaelscover/nightowls/main/src/nightowls/schemas/nightowls.schema.json",
  "title": "Nightowls Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {"type": "string"},
    "timezone": {"type": "string", "enum": ["local", "utc"]},
    "identity_source": {"type": "string", "enum": ["author", "committer"]},
    "output": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "format": {"type": "string", "enum": ["json", "png", "config", "members"]},
        "path": {"type": ["string", "null"]}
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "since": {"type": ["string", "null"]},
        "until": {"type": ["string", "null"]},
        "branch": {"type": ["string", "null"]},
        "no_merges": {"type": "boolean"}
      }
    },
    "members": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "prefixItems": [
          {"type": "string", "minLength": 1},
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": {
                "oneOf": [
                  {"type": "string"},
                  {"$ref": "#/$defs/regex_matcher"},
                  {"type": "null"}
                ]
              },
              "email": {
                "oneOf": [
                  {"type": "string"},
                  {"$ref": "#/$defs/regex_matcher"},
                  {"type": "null"}
                ]
              }
            }
          }
        ]
      }
    }
  },
  "$defs": {
    "regex_matcher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "regex": {"type": "string"}
      },
      "required": ["regex"]
    }
  }
}
